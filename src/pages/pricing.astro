---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PricingCards from '@/components/sections/pricing/PricingCards.astro';
import CompareTable from '@/components/sections/pricing/CompareTable.astro';
import PricingFAQ from '@/components/sections/pricing/PricingFAQ.astro';
import CTABand from '@/components/sections/home/CTABand.astro';
---

<BaseLayout
  title="Pricing"
  description="Transparent monthly retainer plans for social media, paid advertising, email marketing, and more. Find the right plan for your business."
>
  <!-- Compact pricing hero — minimal vertical footprint so cards land above the fold -->
  <section class="pt-36 pb-8 px-6 bg-[var(--color-bg)] relative overflow-hidden">
    <!-- Blue glow, center-top -->
    <div
      class="absolute pointer-events-none rounded-full"
      aria-hidden="true"
      style="top: -450px; left: 50%; transform: translateX(-50%); width: 1000px; height: 1000px;
             filter: blur(120px);
             background: rgba(79,110,247,0.18);"
    ></div>
    <!-- Violet glow, bottom-right -->
    <div
      class="absolute pointer-events-none rounded-full"
      aria-hidden="true"
      style="bottom: -120px; right: -60px; width: 400px; height: 400px;
             filter: blur(60px);
             background: rgba(124,58,237,0.14);"
    ></div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-5">· Pricing</p>

        <h1
          class="font-[var(--font-heading)] text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.08] text-[var(--color-text)] mb-5"
          data-animate-heading
        >
          Plans built for<br>
          <span style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
            real growth.
          </span>
        </h1>

        <div data-animate-body>
          <p class="text-base md:text-lg text-[var(--color-text-muted)] leading-relaxed max-w-xl">
            No hidden fees. No long-term lock-in. Just a focused team and measurable results from day one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <PricingCards />
  <CompareTable />
  <PricingFAQ />
  <CTABand />
</BaseLayout>
