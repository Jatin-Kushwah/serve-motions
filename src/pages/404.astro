---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Return to NovaMark Digital's homepage."
>
  <section class="min-h-screen flex items-center justify-center px-6 py-32">
    <div class="text-center max-w-lg">
      <p class="font-[var(--font-heading)] text-[clamp(6rem,20vw,12rem)] font-extrabold text-[var(--color-surface)] leading-none select-none" aria-hidden="true">
        404
      </p>
      <h1 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4 -mt-4">
        Page not found
      </h1>
      <p class="text-[var(--color-text-muted)] mb-10">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <Button href="/" variant="primary">Back to Home</Button>
    </div>
  </section>
</BaseLayout>
