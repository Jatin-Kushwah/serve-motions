---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Return to Serve Motions' homepage."
>
  <section class="min-h-screen flex items-center justify-center px-6 py-32 bg-[var(--color-bg)] relative overflow-hidden">
    <!-- Background orb -->
    <div class="absolute pointer-events-none" aria-hidden="true" style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 60vw; height: 60vw; max-width: 700px; max-height: 700px; background: radial-gradient(ellipse 70% 70% at center, rgba(79,110,247,0.06), transparent);"></div>

    <div class="text-center max-w-lg relative z-10">
      <p
        class="font-[var(--font-heading)] font-extrabold leading-none select-none mb-4"
        style="font-size: clamp(8rem, 20vw, 18rem); background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        aria-hidden="true"
      >
        404
      </p>
      <h1 class="font-[var(--font-heading)] text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-4">
        You've wandered off the map.
      </h1>
      <p class="text-[var(--color-text-muted)] mb-10 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <Button href="/" variant="gradient">Back to Home</Button>
    </div>
  </section>
</BaseLayout>
