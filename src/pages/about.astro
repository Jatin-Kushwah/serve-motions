---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AboutHero from '@/components/sections/about/AboutHero.astro';
import ValuesSection from '@/components/sections/about/ValuesSection.astro';
import TeamGrid from '@/components/sections/about/TeamGrid.astro';
import MilestoneTimeline from '@/components/sections/about/MilestoneTimeline.astro';
import SectionCTA from '@/components/ui/SectionCTA.astro';
---

<BaseLayout
  title="About NovaMark Digital"
  description="Meet the team behind NovaMark Digital — strategy-first marketers who measure success by your revenue, not vanity metrics."
>
  <div class="about-page">
    <AboutHero />
    <ValuesSection />
    <TeamGrid />
    <MilestoneTimeline />
    <SectionCTA headline="Join Our Growing Client List" cta="Get in Touch" href="/contact" />
  </div>
</BaseLayout>
