---
import Button from '@/components/ui/Button.astro';
import { services } from '@/data/services';

const url = Astro.url;
const success = url.searchParams.get('success') === 'true';
---

{success ? (
  <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-12 text-center">
    <div class="w-16 h-16 bg-[var(--color-accent)] rounded-full flex items-center justify-center mx-auto mb-6">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
        <path d="M5 14l7 7L23 7" stroke="var(--color-text)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <h2 class="font-[var(--font-heading)] text-2xl font-bold text-[var(--color-text)] mb-3">Message sent!</h2>
    <p class="text-[var(--color-text-muted)]">We'll be in touch within 24 hours. Talk soon.</p>
  </div>
) : (
  <form
    name="contact"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    action="/contact?success=true"
    class="space-y-6"
    id="contact-form"
  >
    <input type="hidden" name="form-name" value="contact" />

    <!-- Honeypot (hidden from humans) -->
    <div style="display:none;" aria-hidden="true">
      <label>
        Don't fill this out
        <input name="bot-field" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      <div>
        <label for="name" class="block text-sm font-semibold text-[var(--color-text)] mb-2">
          Name <span class="text-[var(--color-accent-alt)]">*</span>
        </label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Your name"
          class="w-full min-h-[44px] px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-border)] focus:outline-none focus:border-[var(--color-accent-alt)] transition-colors text-sm"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-semibold text-[var(--color-text)] mb-2">
          Email <span class="text-[var(--color-accent-alt)]">*</span>
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="you@company.com"
          class="w-full min-h-[44px] px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-border)] focus:outline-none focus:border-[var(--color-accent-alt)] transition-colors text-sm"
        />
      </div>
    </div>

    <div>
      <label for="company" class="block text-sm font-semibold text-[var(--color-text)] mb-2">
        Company <span class="text-[var(--color-text-muted)] font-normal">(optional)</span>
      </label>
      <input
        type="text"
        id="company"
        name="company"
        placeholder="Your company name"
        class="w-full min-h-[44px] px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-border)] focus:outline-none focus:border-[var(--color-accent-alt)] transition-colors text-sm"
      />
    </div>

    <div>
      <label for="service" class="block text-sm font-semibold text-[var(--color-text)] mb-2">
        Service interest
      </label>
      <select
        id="service"
        name="service"
        class="w-full min-h-[44px] px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:border-[var(--color-accent-alt)] transition-colors text-sm appearance-none cursor-pointer"
      >
        <option value="">Select a service...</option>
        {services.map((s) => (
          <option value={s.id}>{s.name}</option>
        ))}
        <option value="not-sure">Not sure yet</option>
      </select>
    </div>

    <div>
      <label for="message" class="block text-sm font-semibold text-[var(--color-text)] mb-2">
        Message <span class="text-[var(--color-accent-alt)]">*</span>
      </label>
      <textarea
        id="message"
        name="message"
        required
        rows={5}
        placeholder="Tell us about your project, goals, and timeline..."
        class="w-full px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder:text-[var(--color-border)] focus:outline-none focus:border-[var(--color-accent-alt)] transition-colors text-sm resize-none"
      ></textarea>
    </div>

    <button
      type="submit"
      id="submit-btn"
      class="w-full min-h-[52px] bg-[var(--color-accent)] text-[var(--color-text)] font-semibold rounded-full py-4 hover:brightness-110 transition-all duration-300 text-sm tracking-wide cursor-pointer"
    >
      Send Message
    </button>
  </form>
)}

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  if (form && btn) {
    form.addEventListener('submit', () => {
      btn.textContent = 'Sending…';
      btn.disabled = true;
    });
  }
</script>
