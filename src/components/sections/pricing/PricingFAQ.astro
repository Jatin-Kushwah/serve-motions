---
import { pricingFaqs } from '@/data/pricing-faq';
---

<section class="py-28 px-6 bg-[var(--color-bg)]" data-animate>
  <div class="max-w-7xl mx-auto grid lg:grid-cols-[1fr_1.6fr] gap-16 items-start">
    <!-- Left: heading -->
    <div class="lg:sticky lg:top-32">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· Pricing FAQ</p>
      <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight">
        Everything about our plans.
      </h2>
    </div>

    <div id="pricing-faq-list">
      {pricingFaqs.map((faq) => (
        <div class="faq-item border-b border-[var(--color-border)]" data-faq-id={faq.id}>
          <button
            class="faq-trigger w-full flex items-center justify-between gap-8 py-7 text-left cursor-pointer"
            aria-expanded="false"
            data-cursor-hover
          >
            <span class="font-semibold text-[var(--color-text)] text-base md:text-lg pr-4">{faq.question}</span>
            <svg
              class="faq-icon shrink-0 w-5 h-5 text-[var(--color-accent)] transition-transform duration-300"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path d="M5 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-content" aria-hidden="true">
            <p class="text-[var(--color-text-muted)] leading-relaxed pb-7">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const items = document.querySelectorAll<HTMLElement>('#pricing-faq-list .faq-item');

  items.forEach((item) => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger')!;
    const content = item.querySelector<HTMLElement>('.faq-content')!;
    const icon = item.querySelector<SVGElement>('.faq-icon')!;
    let isOpen = false;

    function open() {
      isOpen = true;
      trigger.setAttribute('aria-expanded', 'true');
      content.setAttribute('aria-hidden', 'false');
      icon.classList.add('rotate-45');
      gsap.to(content, {
        height: content.scrollHeight,
        duration: 0.4,
        ease: 'power2.inOut',
      });
    }

    function close() {
      isOpen = false;
      trigger.setAttribute('aria-expanded', 'false');
      content.setAttribute('aria-hidden', 'true');
      icon.classList.remove('rotate-45');
      gsap.killTweensOf(content);
      gsap.to(content, {
        height: 0,
        duration: 0.4,
        ease: 'power2.inOut',
      });
    }

    trigger.addEventListener('click', () => {
      if (isOpen) {
        close();
      } else {
        items.forEach((other) => {
          if (other !== item) {
            const otherTrigger = other.querySelector<HTMLButtonElement>('.faq-trigger')!;
            const otherContent = other.querySelector<HTMLElement>('.faq-content')!;
            const otherIcon = other.querySelector<SVGElement>('.faq-icon')!;
            if (otherTrigger.getAttribute('aria-expanded') === 'true') {
              otherTrigger.setAttribute('aria-expanded', 'false');
              otherContent.setAttribute('aria-hidden', 'true');
              otherIcon.classList.remove('rotate-45');
              gsap.killTweensOf(otherContent);
              gsap.to(otherContent, { height: 0, duration: 0.3, ease: 'power2.inOut' });
            }
          }
        });
        open();
      }
    });

    trigger.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        trigger.click();
      }
    });
  });
</script>
