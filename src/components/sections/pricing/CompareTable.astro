---
import { plans } from '@/data/pricing';

const featureLabels = plans[0].features.map((f) => f.label);
---

<section class="py-20 px-6 bg-[var(--color-surface)]">
  <div class="max-w-5xl mx-auto">

    <!-- Mobile expand toggle -->
    <div class="md:hidden mb-6 text-center">
      <button
        id="compare-toggle"
        class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] border border-[var(--color-border)] rounded-full px-6 py-2.5 cursor-pointer hover:border-[rgba(79,110,247,0.4)] transition-colors duration-200"
        aria-expanded="false"
        data-cursor-hover
      >
        Compare all features
        <svg id="compare-chevron" class="w-4 h-4 transition-transform duration-300" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- Table wrapper — hidden on mobile until toggle -->
    <div id="compare-table-wrap" class="hidden md:block overflow-hidden">
      <div id="compare-table-inner">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="text-left py-4 pr-6 font-semibold text-[var(--color-text-muted)] w-[40%]">Feature</th>
              {plans.map((plan) => (
                <th class="py-4 px-4 text-center font-[var(--font-heading)] font-bold text-[var(--color-text)]">
                  {plan.featured ? (
                    <span
                      style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
                    >
                      {plan.name}
                    </span>
                  ) : plan.name}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {featureLabels.map((label) => (
              <tr class="border-b border-[var(--color-border)] hover:bg-[rgba(255,255,255,0.02)] transition-colors duration-150">
                <td class="py-4 pr-6 text-[var(--color-text-muted)]">{label}</td>
                {plans.map((plan) => {
                  const feature = plan.features.find((f) => f.label === label);
                  const value = feature?.value ?? null;
                  return (
                    <td
                      class="py-4 px-4 text-center"
                      style={plan.featured ? 'background: rgba(79,110,247,0.04);' : ''}
                    >
                      {value !== null ? (
                        <span class="text-[var(--color-text)]">{value}</span>
                      ) : (
                        <span class="text-[var(--color-text-muted)]" aria-label="Not included">—</span>
                      )}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const toggleBtn = document.getElementById('compare-toggle') as HTMLButtonElement | null;
  const chevron = document.getElementById('compare-chevron') as SVGElement | null;
  const tableWrap = document.getElementById('compare-table-wrap') as HTMLElement | null;
  const tableInner = document.getElementById('compare-table-inner') as HTMLElement | null;

  if (toggleBtn && tableWrap && tableInner) {
    let isOpen = false;

    toggleBtn.addEventListener('click', () => {
      isOpen = !isOpen;
      toggleBtn.setAttribute('aria-expanded', String(isOpen));

      if (chevron) {
        chevron.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
      }

      if (isOpen) {
        tableWrap.classList.remove('hidden');
        tableWrap.style.height = '0';
        gsap.to(tableWrap, {
          height: tableInner.scrollHeight,
          duration: 0.45,
          ease: 'power2.inOut',
          onComplete: () => { tableWrap.style.height = 'auto'; },
        });
      } else {
        gsap.to(tableWrap, {
          height: 0,
          duration: 0.35,
          ease: 'power2.inOut',
          onComplete: () => { tableWrap.classList.add('hidden'); },
        });
      }
    });
  }
</script>
