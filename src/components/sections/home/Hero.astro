---
import Button from '@/components/ui/Button.astro';
---

<section id="hero" class="min-h-screen flex flex-col justify-center pt-32 pb-20 px-6 relative overflow-hidden bg-[var(--color-bg)]">
  <!-- Hero image — mobile: full bleed background; desktop: right-side panel -->

  <!-- Mobile full-bleed (hidden on md+) -->
  <div class="absolute inset-0 md:hidden pointer-events-none overflow-hidden" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1773558057883-c15a220761ce?w=800&auto=format&q=75"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <!-- Heavy dark overlay so text stays readable on mobile -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to bottom, rgba(8,12,20,0.78) 0%, rgba(8,12,20,0.70) 50%, rgba(8,12,20,0.90) 100%);"
    ></div>
  </div>

  <!-- Desktop right-panel (hidden below md) -->
  <div class="absolute inset-0 hidden md:block pointer-events-none" aria-hidden="true">
    <div class="absolute right-0 top-0 h-full w-[55%] overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1773558057883-c15a220761ce?w=1400&auto=format&q=80"
        alt="Abstract digital blue network visualization"
        class="w-full h-full object-cover object-center"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <!-- Left-to-right fade: page background → transparent -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to right, var(--color-bg) 0%, rgba(8,12,20,0.7) 30%, rgba(8,12,20,0.2) 60%, transparent 100%);"
      ></div>
      <!-- Bottom fade -->
      <div
        class="absolute inset-x-0 bottom-0 h-40"
        style="background: linear-gradient(to top, var(--color-bg) 0%, transparent 100%);"
      ></div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10">
    <!-- Label -->
    <div class="hero-label mb-8 opacity-0">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">
        · Digital Marketing Agency
      </span>
    </div>

    <!-- Headline — word-clip entrance: each .word is an overflow:hidden container -->
    <div class="overflow-hidden mb-8">
      <h1
        class="font-[var(--font-heading)] text-[clamp(3.5rem,7vw,5.625rem)] lg:text-[clamp(5.625rem,9vw,7.5rem)] font-extrabold leading-[1.0] text-[var(--color-text)] max-w-4xl"
        data-splitting
        aria-label="We Build Brands That Move."
      >
        We Build Brands That <span class="hero-gradient-word" style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Move.</span>
      </h1>
    </div>

    <!-- Sub + CTA row -->
    <div class="hero-sub opacity-0 flex flex-col sm:flex-row items-start sm:items-center gap-8 mt-10">
      <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed max-w-sm">
        Strategy-first digital marketing that drives measurable growth — more traffic, more leads, more revenue.
      </p>
      <div class="flex flex-wrap gap-4 shrink-0">
        <Button href="/contact" variant="gradient">Let's Talk</Button>
        <Button href="/services" variant="outline">Our Services</Button>
      </div>
    </div>
  </div>

  <!-- Circular text badge -->
  <div class="absolute top-32 right-4 sm:right-8 lg:right-12 flex items-center justify-center w-[90px] h-[90px] sm:w-[110px] sm:h-[110px] lg:w-[150px] lg:h-[150px]" aria-hidden="true">
    <svg viewBox="0 0 150 150" width="100%" height="100%" class="shape-rotate absolute inset-0">
      <defs>
        <path id="hero-circle-path" d="M 75,75 m -55,0 a 55,55 0 1,1 110,0 a 55,55 0 1,1 -110,0" />
      </defs>
      <text font-size="10.5" fill="#4F6EF7" font-family="var(--font-body)" font-weight="600" letter-spacing="2.5">
        <textPath href="#hero-circle-path">SERVE MOTIONS · DIGITAL AGENCY · </textPath>
      </text>
    </svg>
    <div class="absolute z-10 w-5 h-5 sm:w-6 sm:h-6 lg:w-8 lg:h-8 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, #4F6EF7, #7C3AED);">
      <svg class="w-[8px] h-[8px] sm:w-[10px] sm:h-[10px] lg:w-[14px] lg:h-[14px]" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="white" stroke="white" stroke-width="1" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-12 right-12 hidden lg:block" aria-hidden="true">
    <div class="w-px h-24 bg-[var(--color-border)] mx-auto mb-3"></div>
    <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-[0.2em] rotate-90 origin-center translate-x-8">Scroll</p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', async () => {
    const words = Array.from(document.querySelectorAll<HTMLElement>('[data-splitting] .word'));

    // Word-clip setup: wrap each .word in overflow:hidden clip box, then animate the .word itself
    // 110% prevents subpixel letter-bottom peek-through on Safari
    words.forEach((word) => {
      const clipBox = document.createElement('span');
      clipBox.style.cssText = 'display: inline-block; overflow: hidden; vertical-align: bottom;';
      word.parentNode!.insertBefore(clipBox, word);
      clipBox.appendChild(word);
    });

    const tl = gsap.timeline({ delay: 0.7 });

    tl.fromTo(
      '.hero-label',
      { opacity: 0, y: 10 },
      { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }
    )
    .fromTo(
      words,
      { y: '110%' },
      { y: '0%', duration: 0.85, ease: 'expo.out', stagger: 0.06, immediateRender: false },
      '-=0.2'
    )
    .fromTo(
      '.hero-sub',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' },
      '-=0.3'
    );
  });

  mm.add('(prefers-reduced-motion: reduce)', () => {
    document.querySelectorAll('.hero-label, .hero-sub').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
    });
  });
</script>
