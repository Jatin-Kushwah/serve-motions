---
import Button from '@/components/ui/Button.astro';
---

<section id="hero" class="min-h-screen flex flex-col justify-center pt-32 pb-20 px-6 relative overflow-hidden bg-[var(--color-bg)]">
  <!-- Three.js canvas container — JS appends canvas here; hidden on mobile -->
  <div id="hero-canvas-container" class="absolute inset-0 pointer-events-none z-0 hidden md:block" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto w-full relative z-10">
    <!-- Label -->
    <div class="hero-label mb-8 opacity-0">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]">
        · Digital Marketing Agency
      </span>
    </div>

    <!-- Headline — word-clip entrance: each .word is an overflow:hidden container -->
    <div class="overflow-hidden mb-8">
      <h1
        class="font-[var(--font-heading)] text-[clamp(3.5rem,7vw,5.625rem)] lg:text-[clamp(5.625rem,9vw,7.5rem)] font-extrabold leading-[1.0] text-[var(--color-text)] max-w-4xl"
        data-splitting
        aria-label="We Build Brands That Move."
      >
        We Build Brands That <span class="hero-gradient-word" style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Move.</span>
      </h1>
    </div>

    <!-- Sub + CTA row -->
    <div class="hero-sub opacity-0 flex flex-col sm:flex-row items-start sm:items-center gap-8 mt-10">
      <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed max-w-sm">
        Strategy-first digital marketing that drives measurable growth — more traffic, more leads, more revenue.
      </p>
      <div class="flex flex-wrap gap-4 shrink-0">
        <Button href="/contact" variant="gradient">Let's Talk</Button>
        <Button href="/services" variant="outline">Our Services</Button>
      </div>
    </div>
  </div>

  <!-- Circular text badge (desktop only) -->
  <div class="absolute top-32 right-12 hidden lg:flex items-center justify-center" aria-hidden="true" style="width: 150px; height: 150px;">
    <svg viewBox="0 0 150 150" width="150" height="150" class="shape-rotate absolute inset-0">
      <defs>
        <path id="hero-circle-path" d="M 75,75 m -55,0 a 55,55 0 1,1 110,0 a 55,55 0 1,1 -110,0" />
      </defs>
      <text font-size="10.5" fill="#4F6EF7" font-family="var(--font-body)" font-weight="600" letter-spacing="2.5">
        <textPath href="#hero-circle-path">SERVE MOTIONS · DIGITAL AGENCY · </textPath>
      </text>
    </svg>
    <div class="absolute z-10 w-8 h-8 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, #4F6EF7, #7C3AED);">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" fill="white" stroke="white" stroke-width="1" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-12 right-12 hidden lg:block" aria-hidden="true">
    <div class="w-px h-24 bg-[var(--color-border)] mx-auto mb-3"></div>
    <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-[0.2em] rotate-90 origin-center translate-x-8">Scroll</p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', async () => {
    const words = Array.from(document.querySelectorAll<HTMLElement>('[data-splitting] .word'));

    // Word-clip setup: wrap each .word in overflow:hidden clip box, then animate the .word itself
    // 110% prevents subpixel letter-bottom peek-through on Safari
    words.forEach((word) => {
      const clipBox = document.createElement('span');
      clipBox.style.cssText = 'display: inline-block; overflow: hidden; vertical-align: bottom;';
      word.parentNode!.insertBefore(clipBox, word);
      clipBox.appendChild(word);
    });

    const tl = gsap.timeline({ delay: 0.7 });

    tl.fromTo(
      '.hero-label',
      { opacity: 0, y: 10 },
      { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }
    )
    .fromTo(
      words,
      { y: '110%' },
      { y: '0%', duration: 0.85, ease: 'expo.out', stagger: 0.06, immediateRender: false },
      '-=0.2'
    )
    .fromTo(
      '.hero-sub',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' },
      '-=0.3'
    );

    // Three.js WebGL canvas — lazy-loaded; mobile-guarded
    if (window.matchMedia('(max-width: 767px)').matches) return;

    try {
      const THREE = await import('three');

      const container = document.getElementById('hero-canvas-container');
      if (!container) return;

      // Renderer
      const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      renderer.setSize(container.offsetWidth, container.offsetHeight);
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.2;
      container.appendChild(renderer.domElement);

      // Scene + camera
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(75, container.offsetWidth / container.offsetHeight, 0.1, 100);
      camera.position.set(0, 0, 3.5);

      // Lights
      const keyLight = new THREE.DirectionalLight(0x6B85F8, 1.8);
      keyLight.position.set(3, 2, 2);
      scene.add(keyLight);

      const rimLight = new THREE.PointLight(0x9D55FF, 0.8, 20);
      rimLight.position.set(-3, -1, -2);
      scene.add(rimLight);

      scene.add(new THREE.AmbientLight(0xffffff, 0.15));

      // Mesh
      const geometry = new THREE.TorusKnotGeometry(1, 0.3, 100, 16);
      const material = new THREE.MeshStandardMaterial({
        color: 0x4F6EF7,
        emissive: 0x1A2880,
        emissiveIntensity: 0.3,
        metalness: 0.6,
        roughness: 0.25,
        transparent: true,
        opacity: 1.0,
      });
      const mesh = new THREE.Mesh(geometry, material);
      // Position mesh in the right side of the hero
      mesh.position.set(2.5, 0, 0);
      scene.add(mesh);

      // Delta-time rotation — decoupled from frame rate
      const clock = new THREE.Clock();

      // Scroll exit via proxy — GSAP can't tween Vector3 or setScalar directly
      const proxy = { progress: 0 };
      gsap.to(proxy, {
        progress: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: 'bottom top',
          scrub: 1,
        },
        onUpdate: () => {
          mesh.scale.setScalar(1 - proxy.progress * 0.5);
          material.opacity = 1 - proxy.progress;
        },
      });

      // Mouse parallax — overwrite:auto cancels in-flight tweens on rapid movement
      document.getElementById('hero')?.addEventListener('mousemove', (e) => {
        const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
        const normX = (e.clientX - rect.left) / rect.width - 0.5;
        const normY = (e.clientY - rect.top) / rect.height - 0.5;
        gsap.to(camera.position, {
          x: normX * 0.12,
          y: -normY * 0.08,
          duration: 0.4,
          ease: 'power1.out',
          overwrite: 'auto',
        });
      });

      // Resize handler
      const onResize = () => {
        renderer.setSize(container.offsetWidth, container.offsetHeight);
        camera.aspect = container.offsetWidth / container.offsetHeight;
        camera.updateProjectionMatrix();
      };
      window.addEventListener('resize', onResize);

      // Animation loop
      const animate = () => {
        requestAnimationFrame(animate);
        const delta = clock.getDelta();
        mesh.rotation.x += 0.12 * delta;
        mesh.rotation.y += 0.18 * delta;
        renderer.render(scene, camera);
      };
      animate();

      // Recalculate ScrollTrigger offsets after canvas injection
      ScrollTrigger.refresh();

    } catch {
      // WebGL unavailable or Three.js failed — hero renders without canvas, no error surfaced
    }
  });

  mm.add('(prefers-reduced-motion: reduce)', () => {
    document.querySelectorAll('.hero-label, .hero-sub').forEach((el) => {
      (el as HTMLElement).style.opacity = '1';
    });
  });
</script>
