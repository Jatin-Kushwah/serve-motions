---
import Button from '@/components/ui/Button.astro';
---

<section class="py-28 px-6 bg-[var(--color-bg)] relative overflow-hidden" data-animate>
  <!-- Radial blob background -->
  <div class="absolute pointer-events-none" aria-hidden="true" style="right: -5%; top: 50%; transform: translateY(-50%); width: 50vw; height: 50vw; max-width: 600px; max-height: 600px; background: radial-gradient(ellipse 60% 80% at 80% 50%, rgba(79,110,247,0.08), transparent);"></div>
  <div class="absolute pointer-events-none" aria-hidden="true" style="left: -5%; bottom: -10%; width: 30vw; height: 30vw; max-width: 400px; max-height: 400px; background: radial-gradient(ellipse 70% 70% at center, rgba(124,58,237,0.06), transparent);"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-6">· Ready to grow?</p>
    <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl lg:text-6xl font-extrabold text-[var(--color-text)] leading-tight mb-6">
      Ready to grow your <br />
      <span style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">business online?</span>
    </h2>
    <p class="text-[var(--color-text-muted)] text-lg leading-relaxed mb-10 max-w-xl mx-auto">
      Let's build something that moves people — and moves the needle on your bottom line.
    </p>
    <Button href="/contact" variant="gradient">Let's Talk</Button>
  </div>
</section>
