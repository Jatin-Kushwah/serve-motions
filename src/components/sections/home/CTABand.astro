---
import Button from '@/components/ui/Button.astro';
---

<section class="py-28 px-6 bg-[var(--color-bg)] relative overflow-hidden" data-animate>
  <div class="absolute pointer-events-none" aria-hidden="true"
       style="width: 900px; height: 900px; top: -414px; right: -414px;
              background: radial-gradient(circle, transparent 0%, rgba(79,110,247,0.01) 3%, rgba(79,110,247,0.02) 6%, rgba(79,110,247,0.06) 9%, rgba(79,110,247,0.11) 11%, rgba(79,110,247,0.15) 12%, rgba(79,110,247,0.15) 20%, rgba(79,110,247,0.15) 15%, rgba(79,110,247,0.11) 30%, rgba(79,110,247,0.06) 40%, rgba(79,110,247,0.02) 50%, rgba(79,110,247,0.01) 5%, transparent 100%);"></div>
  <div class="absolute pointer-events-none" aria-hidden="true"
       style="width: 550px; height: 550px; bottom: -253px; left: -253px;
              background: radial-gradient(circle, transparent 0%, rgba(124,58,237,0.01) 3%, rgba(124,58,237,0.02) 6%, rgba(124,58,237,0.06) 9%, rgba(124,58,237,0.11) 11%, rgba(124,58,237,0.15) 12%, rgba(124,58,237,0.15) 20%, rgba(124,58,237,0.15) 15%, rgba(124,58,237,0.11) 30%, rgba(124,58,237,0.06) 40%, rgba(124,58,237,0.02) 50%, rgba(124,58,237,0.01) 5%, transparent 100%);"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-6">· Ready to grow?</p>
    <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl lg:text-6xl font-extrabold text-[var(--color-text)] leading-tight mb-6">
      Ready to grow your <br />
      <span style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">business online?</span>
    </h2>
    <p class="text-[var(--color-text-muted)] text-lg leading-relaxed mb-10 max-w-xl mx-auto">
      Let's build something that moves people — and moves the needle on your bottom line.
    </p>
    <Button href="/contact" variant="gradient">Let's Talk</Button>
  </div>
</section>
