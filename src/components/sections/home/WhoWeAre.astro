---
const stats = [
  { value: 200, suffix: '+', label: 'Clients worldwide' },
  { value: 98, suffix: '%', label: 'Client retention rate' },
  { value: 5, suffix: '×', label: 'Average ROI delivered' },
];
---

<section class="py-28 px-6 bg-[var(--color-bg)]" data-animate>
  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
    <!-- Left: copy + stats -->
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-6">· Who We Are</p>
      <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight mb-8">
        We don't do vanity metrics. We do results.
      </h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed mb-5">
        Serve Motions was founded on a simple belief: marketing should make businesses money. Not just generate impressions, likes, or reports that sound impressive but mean nothing.
      </p>
      <p class="text-[var(--color-text-muted)] leading-relaxed mb-12">
        Every strategy we build is grounded in your commercial goals. We work as an extension of your team — accountable, proactive, and obsessed with measurable outcomes.
      </p>

    </div>

    <!-- Right: stat cards -->
    <div class="flex flex-col gap-5">
      {stats.map(({ value, suffix, label }, i) => (
        <div
          class="relative rounded-2xl border border-[var(--color-border)] p-8 overflow-hidden"
          style="background: var(--color-surface-2);"
        >
          <!-- Subtle accent orb per card -->
          <div
            class="absolute -top-8 -right-8 w-32 h-32 rounded-full pointer-events-none"
            style={`background: radial-gradient(circle, ${i === 0 ? 'rgba(79,110,247,0.12)' : i === 1 ? 'rgba(124,58,237,0.10)' : 'rgba(79,110,247,0.08)'}, transparent);`}
            aria-hidden="true"
          ></div>
          <div class="flex items-baseline gap-2 mb-3">
            <span
              class="stats-number font-[var(--font-heading)] text-6xl font-extrabold"
              style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
              data-counter
              data-target={value}
            >0</span>
            <span
              class="font-[var(--font-heading)] text-4xl font-extrabold"
              style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
            >{suffix}</span>
          </div>
          <p class="text-[var(--color-text-muted)] font-medium text-sm">{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
