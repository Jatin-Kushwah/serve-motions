---
import { work } from '@/data/work';
import Button from '@/components/ui/Button.astro';
---

<style>
  .glow-fw-violet {
    width: 1000px; height: 1000px;
    top: -460px; right: -460px;
  }
  .glow-fw-blue {
    width: 600px; height: 600px;
    top: 15%; left: -270px;
  }
  @media (max-width: 767px) {
    .glow-fw-violet {
      width: 550px; height: 550px;
      top: -240px; right: -240px;
    }
    .glow-fw-blue {
      width: 300px; height:300px;
      top: 55%; left: -126px;
    }
  }

  [data-work-img] {
    will-change: transform;
  }
</style>

<section id="featured-work" class="py-28 px-6 bg-[var(--color-bg)] relative overflow-hidden">
  <div class="absolute pointer-events-none rounded-full glow-fw-violet" aria-hidden="true"
       style="filter: blur(120px); background: rgba(124,58,237,0.14);"></div>
  <div class="absolute pointer-events-none rounded-full glow-fw-blue" aria-hidden="true"
       style="filter: blur(80px); background: rgba(79,110,247,0.18);"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· Our Work</p>
        <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight" data-animate-heading>
          Proof that strategy wins.
        </h2>
      </div>
      <Button href="/contact" variant="outline">
        View All Work
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate-work>
      {work.map((item, i) => (
        <article
          class:list={[
            'work-card rounded-2xl overflow-hidden group relative cursor-pointer',
            i === 0 ? 'md:col-span-2' : '',
          ]}
          data-cursor-hover
        >
          <div
            class:list={[
              'flex flex-col justify-end p-8 relative',
              i === 0 ? 'aspect-[4/3] md:aspect-[3/2]' : 'aspect-[4/3]',
            ]}
            style={item.image ? undefined : `background: ${item.bgGradient};`}
            role="img"
            aria-label={`${item.client} case study`}
          >
            <!-- Background photo -->
            {item.image && (
              <>
                <img
                  src={item.image}
                  alt=""
                  class="absolute inset-0 w-full h-full object-cover object-center"
                  loading="lazy"
                  decoding="async"
                  aria-hidden="true"
                  data-work-img
                />
                <div
                  class="absolute inset-0 pointer-events-none"
                  style="background: linear-gradient(to top, rgba(11,11,26,0.92) 0%, rgba(11,11,26,0.4) 50%, transparent 100%);"
                  aria-hidden="true"
                ></div>
              </>
            )}

            <!-- Overlay -->
            <div class="work-card-overlay rounded-none">
              <span class="text-sm font-semibold text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide">
                View Project →
              </span>
            </div>

            <!-- Category tag -->
            <span class="absolute top-6 left-6 text-xs font-semibold uppercase tracking-[0.15em] text-white/60 bg-white/10 backdrop-blur-sm rounded-full px-3 py-1 z-10">
              {item.category}
            </span>

            <!-- Bottom content -->
            <div class="relative z-10">
              <p
                class="font-[var(--font-heading)] text-6xl font-extrabold mb-1"
                style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;"
              >
                {item.metric}
              </p>
              <p class="text-sm text-white/60 mb-3">{item.metricLabel}</p>
              <h3 class="font-[var(--font-heading)] text-xl font-bold text-white">{item.client}</h3>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference) and (pointer: fine)', () => {
    document.querySelectorAll<HTMLElement>('.work-card').forEach((card) => {
      const img = card.querySelector<HTMLElement>('[data-work-img]');
      if (!img) return;

      const xTo = gsap.quickTo(img, 'x', { duration: 0.4, ease: 'power3.out' });
      const yTo = gsap.quickTo(img, 'y', { duration: 0.4, ease: 'power3.out' });

      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const nx = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
        const ny = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
        xTo(nx * 12);
        yTo(ny * 8);
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(img, { x: 0, y: 0, duration: 0.6, ease: 'expo.out' });
      });
    });
  });
</script>
