---
import { work } from '@/data/work';
import Button from '@/components/ui/Button.astro';
---

<style>
  .glow-fw-violet {
    width: 1000px; height: 1000px;
    top: -460px; right: -460px;
  }
  .glow-fw-blue {
    width: 600px; height: 600px;
    top: 15%; left: -270px;
  }
  @media (max-width: 767px) {
    .glow-fw-violet {
      width: 550px; height: 550px;
      top: -240px; right: -240px;
    }
    .glow-fw-blue {
      width: 300px; height:300px;
      top: 55%; left: -126px;
    }
  }
</style>

<section class="py-28 px-6 bg-[var(--color-bg)] relative overflow-hidden">
  <div class="absolute pointer-events-none glow-fw-violet" aria-hidden="true"
       style="background: radial-gradient(circle, transparent 0%, rgba(124,58,237,0.01) 3%, rgba(124,58,237,0.02) 5%, rgba(124,58,237,0.03) 7%, rgba(124,58,237,0.06) 10%, rgba(124,58,237,0.08) 18%, rgba(124,58,237,0.10) 24%, rgba(124,58,237,0.13) 28%, rgba(124,58,237,0.15) 35%, rgba(124,58,237,0.11) 43%, rgba(124,58,237,0.06) 50%, rgba(124,58,237,0.01) 65%, rgba(124,58,237,0.0) 69%, rgba(124,58,237,0.00) 85%, transparent 100%);"></div>
  <div class="absolute pointer-events-none glow-fw-blue" aria-hidden="true"
       style="background: radial-gradient(circle, transparent 0%, rgba(79,110,247,0.01) 3%, rgba(79,110,247,0.02) 5%, rgba(79,110,247,0.03) 7%, rgba(79,110,247,0.06) 10%, rgba(79,110,247,0.08) 18%, rgba(79,110,247,0.10) 24%, rgba(79,110,247,0.13) 28%, rgba(79,110,247,0.15) 35%, rgba(79,110,247,0.11) 43%, rgba(79,110,247,0.06) 50%, rgba(79,110,247,0.01) 65%, rgba(79,110,247,0.0) 69%, rgba(79,110,247,0.00) 85%, transparent 100%);"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· Our Work</p>
        <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight" data-animate-heading>
          Proof that strategy wins.
        </h2>
      </div>
      <Button href="/contact" variant="outline">
        View All Work
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </Button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate-work>
      {work.map((item) => (
        <article class="work-card rounded-2xl overflow-hidden group relative cursor-pointer" data-cursor-hover>
          <div
            class="aspect-[4/3] flex flex-col justify-end p-8 relative"
            style={item.image ? undefined : `background: ${item.bgGradient};`}
            role="img"
            aria-label={`${item.client} case study`}
          >
            <!-- Background photo -->
            {item.image && (
              <>
                <img
                  src={item.image}
                  alt=""
                  class="absolute inset-0 w-full h-full object-cover object-center"
                  loading="lazy"
                  decoding="async"
                  aria-hidden="true"
                />
                <div
                  class="absolute inset-0 pointer-events-none"
                  style="background: linear-gradient(to top, rgba(11,11,26,0.92) 0%, rgba(11,11,26,0.4) 50%, transparent 100%);"
                  aria-hidden="true"
                ></div>
              </>
            )}

            <!-- Overlay -->
            <div class="work-card-overlay rounded-none">
              <span class="text-sm font-semibold text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 tracking-wide">
                View Project →
              </span>
            </div>

            <!-- Category tag -->
            <span class="absolute top-6 left-6 text-xs font-semibold uppercase tracking-[0.15em] text-white/60 bg-white/10 backdrop-blur-sm rounded-full px-3 py-1 z-10">
              {item.category}
            </span>

            <!-- Bottom content -->
            <div class="relative z-10">
              <p class="font-[var(--font-heading)] text-4xl font-extrabold text-[var(--color-accent)] mb-1">
                {item.metric}
              </p>
              <p class="text-sm text-white/60 mb-3">{item.metricLabel}</p>
              <h3 class="font-[var(--font-heading)] text-xl font-bold text-white">{item.client}</h3>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
