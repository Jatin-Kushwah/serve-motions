---
const steps = [
  {
    number: '01',
    name: 'Discovery & Audit',
    description: 'Deep-dive into your business, goals, current performance, and competitive landscape.',
    weeks: 'Week 1–2',
  },
  {
    number: '02',
    name: 'Blueprint',
    description: 'Data-backed strategy document with channel priorities, targeting, creative direction, and KPIs.',
    weeks: 'Week 3',
  },
  {
    number: '03',
    name: 'Build & Launch',
    description: 'Set up tracking, build campaigns, produce creative, and go live with a phased rollout.',
    weeks: 'Week 4–6',
  },
  {
    number: '04',
    name: 'Optimise & Scale',
    description: 'Continuous testing, weekly optimisations, and monthly strategy reviews to compound results.',
    weeks: 'Week 7+',
  },
];
---

<section class="py-28 px-6 bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-start">
    <!-- Left: heading -->
    <div class="lg:sticky lg:top-32">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· Our Process</p>
      <h2
        class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight mb-6"
        data-animate-heading
      >
        How we go from brief to results.
      </h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed">
        A proven four-step framework that turns business goals into measurable growth — no guesswork, no fluff.
      </p>
    </div>

    <!-- Right: steps -->
    <div class="relative">
      <!-- Vertical line track with gradient -->
      <div class="absolute left-6 top-8 bottom-8 w-px" aria-hidden="true"
           style="background: linear-gradient(to bottom, transparent 0%, rgba(79,110,247,0.4) 15%, rgba(124,58,237,0.4) 85%, transparent 100%);">
      </div>

      <div class="process-track space-y-0">
        {steps.map((step) => (
          <div class="process-step flex gap-6 pb-12 last:pb-0">
            <!-- Refined gradient node -->
            <div class="relative z-10 shrink-0">
              <div class="w-12 h-12 rounded-full flex items-center justify-center ring-4 ring-[var(--color-surface)]"
                   style="background: linear-gradient(135deg, #4F6EF7, #7C3AED); box-shadow: 0 0 20px rgba(79,110,247,0.45), 0 0 40px rgba(79,110,247,0.15);">
                <span class="font-[var(--font-heading)] font-extrabold text-sm text-white">{step.number}</span>
              </div>
            </div>
            <!-- Content -->
            <div class="pt-3">
              <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-text-muted)] mb-2">{step.weeks}</p>
              <h3 class="font-[var(--font-heading)] text-xl font-bold text-[var(--color-text)] mb-3">{step.name}</h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.process-step',
      { opacity: 0, x: -24 },
      {
        opacity: 1, x: 0, stagger: 0.14, duration: 0.6, ease: 'power3.out',
        immediateRender: false,
        scrollTrigger: { trigger: '.process-track', start: 'top 75%', once: true }
      }
    );
  });

  mm.add('(prefers-reduced-motion: reduce)', () => {
    gsap.set('.process-step', { opacity: 1, x: 0 });
  });
</script>
