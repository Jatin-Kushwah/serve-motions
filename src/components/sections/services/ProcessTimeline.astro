---
const steps = [
  {
    number: '01',
    name: 'Discovery & Audit',
    description: 'Deep-dive into your business, goals, current performance, and competitive landscape.',
    weeks: 'Week 1–2',
  },
  {
    number: '02',
    name: 'Blueprint',
    description: 'Data-backed strategy document with channel priorities, targeting, creative direction, and KPIs.',
    weeks: 'Week 3',
  },
  {
    number: '03',
    name: 'Build & Launch',
    description: 'Set up tracking, build campaigns, produce creative, and go live with a phased rollout.',
    weeks: 'Week 4–6',
  },
  {
    number: '04',
    name: 'Optimise & Scale',
    description: 'Continuous testing, weekly optimisations, and monthly strategy reviews to compound results.',
    weeks: 'Week 7+',
  },
];
---

<section class="py-28 px-6 bg-[var(--color-surface)]" data-animate>
  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-start">
    <!-- Left: heading -->
    <div class="lg:sticky lg:top-32">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· Our Process</p>
      <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight mb-6">
        How we go from brief to results.
      </h2>
      <p class="text-[var(--color-text-muted)] leading-relaxed">
        A proven four-step framework that turns business goals into measurable growth — no guesswork, no fluff.
      </p>
    </div>

    <!-- Right: steps -->
    <div class="relative">
      <!-- Vertical line track -->
      <div class="absolute left-8 top-8 bottom-8 w-px bg-[var(--color-border)]" aria-hidden="true">
        <div id="timeline-progress" class="w-full bg-[var(--color-accent)] timeline-line h-full"></div>
      </div>

      <div class="space-y-0">
        {steps.map((step) => (
          <div class="flex gap-6 pb-12 last:pb-0">
            <!-- Circle with number -->
            <div class="relative z-10 shrink-0">
              <div class="w-16 h-16 bg-[var(--color-accent)] rounded-full flex items-center justify-center ring-4 ring-[var(--color-surface)]">
                <span class="font-[var(--font-heading)] font-extrabold text-lg text-white">{step.number}</span>
              </div>
            </div>
            <!-- Content -->
            <div class="pt-3">
              <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-text-muted)] mb-2">{step.weeks}</p>
              <h3 class="font-[var(--font-heading)] text-xl font-bold text-[var(--color-text)] mb-3">{step.name}</h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const line = document.getElementById('timeline-progress');
    if (!line) return;

    gsap.to(line, {
      scaleY: 1,
      duration: 1.4,
      ease: 'power2.inOut',
      scrollTrigger: {
        trigger: line,
        start: 'top 75%',
        once: true,
      },
    });
  });

  mm.add('(prefers-reduced-motion: reduce)', () => {
    const line = document.getElementById('timeline-progress');
    if (line) line.style.transform = 'scaleY(1)';
  });
</script>
