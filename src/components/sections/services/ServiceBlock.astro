---
import { Check } from '@lucide/astro';
import type { Service } from '@/data/services';

interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
const isEven = index % 2 === 0;
const num = String(index + 1).padStart(2, '0');
---

<div
  class={`flex flex-col ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-16 items-center py-12 lg:py-20 border-b border-[var(--color-border)] last:border-0`}
  id={service.id}
  data-animate
>
  <!-- Visual panel -->
  <div class="w-full lg:w-1/2 shrink-0 order-2 lg:order-none">
    <div
      class="relative aspect-square lg:aspect-[4/3] rounded-2xl overflow-hidden bg-[var(--color-surface-2)] border border-[var(--color-border)]"
      style={`background: var(--color-surface-2); background-image: ${service.bgGradient.replace('linear-gradient', 'linear-gradient')};`}
    >

      {service.id === 'seo' && (
        <div class="absolute inset-0 flex flex-col justify-center gap-2 lg:gap-3 p-4 lg:p-7">
          <!-- Search bar -->
          <div class="flex items-center gap-2.5 bg-[var(--color-surface)] rounded-xl px-4 py-3 border border-[var(--color-border)]">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <circle cx="5.5" cy="5.5" r="4" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <path d="M9 9l2.5 2.5" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="text-xs text-[var(--color-text-muted)]">best digital marketing agency</span>
          </div>

          <!-- Results -->
          <div class="space-y-2">
            <!-- #1 — client result, highlighted -->
            <div class="bg-[var(--color-surface)] rounded-xl px-4 py-3 border-l-[3px] border-emerald-500 flex items-start gap-3 border border-[var(--color-border)]">
              <span class="shrink-0 mt-0.5 w-5 h-5 rounded-full bg-emerald-500 text-white text-[10px] font-bold flex items-center justify-center">1</span>
              <div class="min-w-0">
                <p class="text-[11px] font-semibold text-[var(--color-accent)] truncate">yourclient.com › services</p>
                <p class="text-xs font-bold text-[var(--color-text)] truncate">Digital Marketing — Results That Scale</p>
                <p class="text-[10px] text-[var(--color-text-muted)] truncate mt-0.5">Award-winning campaigns. Measurable growth across every channel...</p>
              </div>
            </div>
            <!-- #2 — faded competitor -->
            <div class="bg-[rgba(255,255,255,0.03)] rounded-xl px-4 py-3 flex items-start gap-3 opacity-50">
              <span class="shrink-0 mt-0.5 w-5 h-5 rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] text-[10px] font-medium flex items-center justify-center">2</span>
              <div class="flex-1 space-y-1.5">
                <div class="h-2 bg-[rgba(255,255,255,0.06)] rounded-full w-2/3"></div>
                <div class="h-2 bg-[rgba(255,255,255,0.04)] rounded-full w-full"></div>
                <div class="h-2 bg-[rgba(255,255,255,0.04)] rounded-full w-4/5"></div>
              </div>
            </div>
            <!-- #3 — more faded -->
            <div class="bg-[rgba(255,255,255,0.02)] rounded-xl px-4 py-3 flex items-start gap-3 opacity-30">
              <span class="shrink-0 mt-0.5 w-5 h-5 rounded-full border border-[var(--color-border)] text-[var(--color-text-muted)] text-[10px] font-medium flex items-center justify-center">3</span>
              <div class="flex-1 space-y-1.5">
                <div class="h-2 bg-[rgba(255,255,255,0.06)] rounded-full w-1/2"></div>
                <div class="h-2 bg-[rgba(255,255,255,0.04)] rounded-full w-3/4"></div>
              </div>
            </div>
          </div>

          <div class="flex justify-end">
            <span class="text-[11px] font-semibold text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-full border border-emerald-500/20">↑ +312% organic traffic</span>
          </div>
        </div>
      )}

      {service.id === 'social' && (
        <div class="absolute inset-0 p-3 lg:p-6 grid grid-cols-3 grid-rows-3 gap-2">
          <div class="col-span-2 row-span-2 rounded-xl bg-[rgba(139,92,246,0.15)] flex items-center justify-center text-2xl font-bold text-violet-400 font-[var(--font-heading)] border border-[rgba(139,92,246,0.2)]">4.8×</div>
          <div class="rounded-xl bg-[rgba(139,92,246,0.1)] border border-[var(--color-border)]"></div>
          <div class="rounded-xl bg-[rgba(109,40,217,0.08)] border border-[var(--color-border)]"></div>
          <div class="rounded-xl bg-[rgba(139,92,246,0.06)] border border-[var(--color-border)]"></div>
          <div class="col-span-2 rounded-xl bg-[rgba(255,255,255,0.03)] flex items-center gap-3 px-4 border border-[var(--color-border)]">
            <div class="w-7 h-7 rounded-full bg-[rgba(139,92,246,0.3)] shrink-0"></div>
            <div class="flex-1 space-y-1.5">
              <div class="h-2 bg-[rgba(255,255,255,0.08)] rounded-full w-3/4"></div>
              <div class="h-2 bg-[rgba(255,255,255,0.04)] rounded-full w-1/2"></div>
            </div>
          </div>
          <div class="rounded-xl bg-[rgba(109,40,217,0.12)] border border-[var(--color-border)]"></div>
        </div>
      )}

      {service.id === 'paid' && (
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 px-5 py-5 lg:px-10 lg:py-8">
          <div class="w-full text-center">
            <div class="bg-[rgba(245,158,11,0.12)] border border-[rgba(245,158,11,0.2)] rounded-xl py-3 px-4 mb-2">
              <span class="text-xs font-semibold text-amber-400">Awareness</span>
              <span class="float-right text-xs text-amber-300/70">84,200 impressions</span>
            </div>
            <div class="w-0 h-0 mx-auto border-l-[12px] border-r-[12px] border-t-[8px] border-l-transparent border-r-transparent border-t-[rgba(245,158,11,0.3)] mb-2"></div>
          </div>
          <div class="w-5/6 text-center">
            <div class="bg-[rgba(249,115,22,0.1)] border border-[rgba(249,115,22,0.2)] rounded-xl py-3 px-4 mb-2">
              <span class="text-xs font-semibold text-orange-400">Consideration</span>
              <span class="float-right text-xs text-orange-300/70">12,400 clicks</span>
            </div>
            <div class="w-0 h-0 mx-auto border-l-[12px] border-r-[12px] border-t-[8px] border-l-transparent border-r-transparent border-t-[rgba(249,115,22,0.25)] mb-2"></div>
          </div>
          <div class="w-3/5 text-center">
            <div class="rounded-xl py-3 px-4" style="background: linear-gradient(135deg, #4F6EF7, #7C3AED);">
              <span class="text-xs font-semibold text-white">Conversions</span>
              <span class="float-right text-xs text-white/80">2.7× ROAS</span>
            </div>
          </div>
        </div>
      )}

      {service.id === 'brand' && (
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 lg:gap-8 p-5 lg:p-8">
          <div class="text-center">
            <p class="font-[var(--font-heading)] text-6xl lg:text-8xl font-extrabold leading-none select-none" style="background: linear-gradient(135deg, #f472b6, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Aa</p>
            <p class="text-xs text-[var(--color-text-muted)] mt-2 tracking-widest uppercase">Syne Display</p>
          </div>
          <div class="flex gap-3">
            {[
              'rgba(236,72,153,0.8)',
              'rgba(225,29,72,0.6)',
              'rgba(236,72,153,0.4)',
              'rgba(225,29,72,0.25)',
              'rgba(236,72,153,0.12)',
            ].map(bg => (
              <div class="w-10 h-10 rounded-full" style={`background: ${bg};`}></div>
            ))}
          </div>
          <div class="w-full bg-[rgba(255,255,255,0.04)] border border-[var(--color-border)] rounded-xl px-5 py-3 text-center">
            <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-1">Brand Tagline</p>
            <p class="font-[var(--font-heading)] font-bold text-[var(--color-text)] text-sm">Distinct. Consistent. Memorable.</p>
          </div>
        </div>
      )}

      {service.id === 'email' && (
        <div class="absolute inset-0 flex flex-col justify-center px-4 py-4 lg:px-8 lg:py-6 gap-3">
          <div class="bg-[var(--color-surface)] rounded-xl overflow-hidden border border-[var(--color-border)]">
            <div class="bg-[var(--color-surface-2)] px-4 py-2.5 flex items-center gap-2 border-b border-[var(--color-border)]">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/50"></div>
              </div>
              <span class="text-[11px] text-[var(--color-accent)] ml-2 font-medium">Inbox — 3 new</span>
            </div>
            <div class="divide-y divide-[var(--color-border)]">
              <div class="px-4 py-3 flex items-start gap-3">
                <div class="w-7 h-7 rounded-full shrink-0 flex items-center justify-center text-white text-[10px] font-bold" style="background: linear-gradient(135deg, #4F6EF7, #7C3AED);">N</div>
                <div class="flex-1 min-w-0">
                  <div class="flex justify-between items-center mb-1">
                    <span class="text-[11px] font-semibold text-[var(--color-text)]">Serve Motions Team</span>
                    <span class="text-[10px] text-[var(--color-text-muted)]">9:41 AM</span>
                  </div>
                  <p class="text-[11px] text-[var(--color-text-muted)] truncate">Your Q2 campaign hit 41.2% open rate 🎉</p>
                </div>
              </div>
              <div class="px-4 py-2.5 flex items-center gap-3 opacity-40">
                <div class="w-7 h-7 rounded-full bg-[rgba(14,165,233,0.2)] shrink-0"></div>
                <div class="flex-1">
                  <div class="h-2 bg-[rgba(255,255,255,0.06)] rounded w-3/4 mb-1.5"></div>
                  <div class="h-2 bg-[rgba(255,255,255,0.04)] rounded w-1/2"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="flex-1 bg-[rgba(14,165,233,0.06)] rounded-xl px-4 py-3 text-center border border-[rgba(14,165,233,0.15)]">
              <p class="font-[var(--font-heading)] font-bold text-[var(--color-accent)] text-lg">41%</p>
              <p class="text-[10px] text-[var(--color-text-muted)]">Open rate</p>
            </div>
            <div class="flex-1 bg-[rgba(14,165,233,0.06)] rounded-xl px-4 py-3 text-center border border-[rgba(14,165,233,0.15)]">
              <p class="font-[var(--font-heading)] font-bold text-[var(--color-accent)] text-lg">6.2%</p>
              <p class="text-[10px] text-[var(--color-text-muted)]">Click rate</p>
            </div>
            <div class="flex-1 bg-[rgba(14,165,233,0.06)] rounded-xl px-4 py-3 text-center border border-[rgba(14,165,233,0.15)]">
              <p class="font-[var(--font-heading)] font-bold text-[var(--color-accent)] text-lg">38×</p>
              <p class="text-[10px] text-[var(--color-text-muted)]">ROI</p>
            </div>
          </div>
        </div>
      )}

      {service.id === 'web' && (
        <div class="absolute inset-0 flex flex-col justify-center px-4 py-4 lg:px-8 lg:py-6 gap-4">
          <div class="bg-[var(--color-surface)] rounded-xl overflow-hidden border border-[var(--color-border)]">
            <div class="bg-[var(--color-surface-2)] px-4 py-2 flex items-center gap-2 border-b border-[var(--color-border)]">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/50"></div>
              </div>
              <div class="flex-1 bg-[rgba(255,255,255,0.04)] border border-[var(--color-border)] rounded-md px-3 py-1 text-[11px] text-[var(--color-text-muted)] text-center mx-2">
                yourclient.com
              </div>
            </div>
            <div class="p-4 grid grid-cols-4 gap-2">
              {[['98', 'Performance'], ['100', 'SEO'], ['95', 'A11y'], ['100', 'Best Practices']].map(([score, label]) => (
                <div class="text-center">
                  <div class="w-10 h-10 rounded-full border-4 border-emerald-500 flex items-center justify-center mx-auto mb-1">
                    <span class="text-xs font-bold text-emerald-400">{score}</span>
                  </div>
                  <p class="text-[9px] text-[var(--color-text-muted)] leading-tight">{label}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="flex gap-2">
            <div class="flex-1 bg-[rgba(99,102,241,0.08)] rounded-xl px-3 py-2.5 border border-[rgba(99,102,241,0.2)] text-center">
              <p class="font-bold text-[var(--color-accent)] text-base font-[var(--font-heading)]">&lt;0.8s</p>
              <p class="text-[10px] text-[var(--color-text-muted)]">LCP</p>
            </div>
            <div class="flex-1 bg-[rgba(99,102,241,0.08)] rounded-xl px-3 py-2.5 border border-[rgba(99,102,241,0.2)] text-center">
              <p class="font-bold text-[var(--color-accent)] text-base font-[var(--font-heading)]">0.02</p>
              <p class="text-[10px] text-[var(--color-text-muted)]">CLS</p>
            </div>
            <div class="flex-1 bg-[rgba(99,102,241,0.08)] rounded-xl px-3 py-2.5 border border-[rgba(99,102,241,0.2)] text-center">
              <p class="font-bold text-[var(--color-accent)] text-base font-[var(--font-heading)]">Top 1%</p>
              <p class="text-[10px] text-[var(--color-text-muted)]">Speed rank</p>
            </div>
          </div>
        </div>
      )}

    </div>
  </div>

  <!-- Text column -->
  <div class="flex-1 order-1 lg:order-none">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">
      · Service {num}
    </p>
    <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-6 leading-tight">
      {service.name}
    </h2>
    <p class="text-[var(--color-text-muted)] leading-relaxed mb-8">
      {service.description}
    </p>
    <ul class="space-y-3 mb-8">
      {service.bullets.map((bullet) => (
        <li class="flex items-start gap-3 text-sm text-[var(--color-text)]">
          <span class="mt-0.5 shrink-0 w-5 h-5 bg-[var(--color-accent)] rounded-full flex items-center justify-center text-white">
            <Check size={11} stroke-width={3} />
          </span>
          {bullet}
        </li>
      ))}
    </ul>
    <a href="/contact" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] hover:gap-3 transition-all" data-cursor-hover>
      Get started
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10M8.5 3.5l3.5 3.5-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</div>
