---
import { Lightbulb, Eye, BarChart2, Users } from '@lucide/astro';

const values = [
  {
    icon: Lightbulb,
    title: 'Innovation',
    description: 'We stay ahead of platform changes, algorithm shifts, and new channels so you never fall behind.',
  },
  {
    icon: Eye,
    title: 'Transparency',
    description: 'No jargon, no hidden fees, no vanity metrics. You always know exactly what we\'re doing and why.',
  },
  {
    icon: BarChart2,
    title: 'Results',
    description: 'We measure success the same way you do — revenue, leads, and growth. Not likes and impressions.',
  },
  {
    icon: Users,
    title: 'Partnership',
    description: 'We work as an extension of your team, not a vendor. Your goals are our goals.',
  },
];
---

<style>
  .values-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    border: 1px solid var(--color-border);
  }
  .values-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 32px rgba(79, 110, 247, 0.12), var(--shadow-card);
    border-color: rgba(79, 110, 247, 0.3);
  }
  .values-icon {
    transition: background-color 0.3s ease, color 0.3s ease, background 0.3s ease;
  }
  .values-card:hover .values-icon {
    background: linear-gradient(135deg, #4F6EF7, #7C3AED);
    color: white;
  }
</style>

<section class="py-28 px-6 bg-[var(--color-surface)]">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· Our Values</p>
      <h2
        class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight max-w-md"
        data-animate-heading
      >
        What we stand for.
      </h2>
    </div>

    <div class="values-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {values.map(({ icon: Icon, title, description }) => (
        <article class="values-card bg-[var(--color-bg)] rounded-2xl p-8">
          <div class="values-icon w-12 h-12 text-[var(--color-accent)] bg-[var(--color-surface)] rounded-xl flex items-center justify-center mb-6">
            <Icon size={22} />
          </div>
          <h3 class="font-[var(--font-heading)] text-xl font-bold text-[var(--color-text)] mb-3">{title}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.fromTo('.values-card',
      { opacity: 0, y: 40 },
      {
        opacity: 1, y: 0, stagger: 0.08, duration: 0.55, ease: 'power3.out',
        immediateRender: false,
        scrollTrigger: { trigger: '.values-grid', start: 'top 80%', once: true }
      }
    );
  });

  mm.add('(prefers-reduced-motion: reduce)', () => {
    gsap.set('.values-card', { opacity: 1, y: 0 });
  });
</script>
