---
import { team } from '@/data/team';
---

<section class="py-28 px-6 bg-[var(--color-bg)]" data-animate>
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· The Team</p>
      <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight max-w-md">
        The people behind the results.
      </h2>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8">
      {team.map((member) => (
        <article class="flex flex-col items-center text-center group">
          <!-- Avatar placeholder -->
          <div
            class="w-20 h-20 rounded-full flex items-center justify-center mb-4 text-white font-[var(--font-heading)] font-bold text-lg"
            style={`background-color: ${member.bg};`}
            aria-hidden="true"
          >
            {member.initials}
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm mb-0.5">{member.name}</p>
          <p class="text-xs text-[var(--color-text-muted)] mb-3 leading-snug">{member.role}</p>
          <a href="#" class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors" aria-label={`${member.name} on LinkedIn`} data-cursor-hover>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
