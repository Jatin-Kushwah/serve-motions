---
---

<section class="relative min-h-[70vh] flex items-center overflow-hidden pt-32 pb-20 px-6">
  <!-- Atmospheric glow system -->
  <div class="absolute pointer-events-none rounded-full" aria-hidden="true" style="
    width: 900px; height: 900px;
    top: -400px; right: -300px;
    filter: blur(100px);
    background: rgba(79,110,247,0.18);
  "></div>
  <div class="absolute pointer-events-none rounded-full" aria-hidden="true" style="
    width: 500px; height: 500px;
    bottom: -200px; left: -150px;
    filter: blur(70px);
    background: rgba(124,58,237,0.14);
  "></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto w-full">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-6">· Our Story</p>
    <h1
      class="font-[var(--font-heading)] text-5xl md:text-6xl lg:text-7xl font-extrabold text-[var(--color-text)] leading-[1.05] mb-8 max-w-3xl"
      data-animate-heading
      aria-label="We Are Serve Motions."
    >
      We Are Serve Motions.
    </h1>
    <div data-animate-body>
      <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed max-w-xl">
        Born from the belief that great marketing is a business strategy, not a checkbox. We exist to make brands matter.
      </p>
    </div>
  </div>
</section>
