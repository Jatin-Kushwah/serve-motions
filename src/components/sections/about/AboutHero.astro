---
---

<section class="relative min-h-[70vh] flex items-center overflow-hidden pt-32 pb-20 px-6">
  <!-- Animated SVG shapes -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <svg class="absolute -top-20 -right-20 w-96 h-96 shape-rotate opacity-10" viewBox="0 0 200 200" fill="none">
      <polygon points="100,10 190,55 190,145 100,190 10,145 10,55" fill="var(--color-accent)" />
    </svg>
    <svg class="absolute top-1/3 -left-16 w-64 h-64 shape-float opacity-10" viewBox="0 0 200 200" fill="none">
      <circle cx="100" cy="100" r="90" fill="var(--color-accent-alt)" />
    </svg>
    <svg class="absolute bottom-10 right-1/4 w-48 h-48 shape-float-alt opacity-15" viewBox="0 0 200 200" fill="none">
      <polygon points="100,20 180,80 160,170 40,170 20,80" fill="var(--color-accent)" />
    </svg>
    <svg class="absolute top-1/4 left-1/3 w-32 h-32 shape-rotate opacity-10" style="animation-duration: 60s;" viewBox="0 0 200 200" fill="none">
      <rect x="20" y="20" width="160" height="160" rx="20" fill="var(--color-accent-alt)" />
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto w-full">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent-alt)] mb-6">Our Story</p>
    <h1
      class="font-[var(--font-heading)] text-5xl md:text-6xl lg:text-7xl font-extrabold text-[var(--color-text)] leading-[1.05] mb-8 max-w-3xl"
      data-splitting
      aria-label="We Are NovaMark."
    >
      We Are NovaMark.
    </h1>
    <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed max-w-xl">
      Born from the belief that great marketing is a business strategy, not a checkbox. We exist to make brands matter.
    </p>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const chars = document.querySelectorAll('#about-hero [data-splitting] .char, .about-page [data-splitting] .char');
    if (chars.length === 0) return;

    gsap.fromTo(
      chars,
      { yPercent: 100, opacity: 0 },
      { yPercent: 0, opacity: 1, duration: 0.7, ease: 'power3.out', stagger: 0.025, delay: 0.4 }
    );
  });
</script>
