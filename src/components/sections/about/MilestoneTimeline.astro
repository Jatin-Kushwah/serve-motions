---
const milestones = [
  {
    year: '2020',
    title: 'Founded',
    description: 'Serve Motions launched with three clients and a clear mission: results over reports.',
  },
  {
    year: '2021',
    title: 'First 50 Clients',
    description: 'Expanded from SEO into paid media and brand identity. Team grew to 12 specialists.',
  },
  {
    year: '2023',
    title: 'International Expansion',
    description: "Opened new markets in the UK and Singapore. Recognised in Marketing Week's Top 50 Agencies.",
  },
  {
    year: '2025',
    title: '200+ Clients',
    description: 'Serving growth-stage brands across 18 industries. $120M in tracked client revenue growth.',
  },
];
---

<section class="py-28 px-6 bg-[var(--color-surface)]" data-animate>
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)] mb-4">· Our Journey</p>
      <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight max-w-md">
        Five years of earned growth.
      </h2>
    </div>

    <!-- Universal vertical alternating layout -->
    <div class="relative max-w-4xl mx-auto">
      <!-- Vertical center line (desktop) -->
      <div class="absolute left-1/2 top-0 bottom-0 w-px bg-[var(--color-border)] -translate-x-1/2 hidden md:block" aria-hidden="true"></div>
      <!-- Vertical left line (mobile) -->
      <div class="absolute left-5 top-0 bottom-0 w-px bg-[var(--color-border)] md:hidden" aria-hidden="true"></div>

      <div class="space-y-0">
        {milestones.map((m, i) => (
          <div class={`relative flex items-start gap-0 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} flex-row`}>
            <!-- Mobile layout: content with left indent -->
            <div class="md:hidden flex gap-6 w-full pb-12">
              <!-- Circle node (mobile) -->
              <div class="relative shrink-0 z-10 mt-1">
                <div class="w-10 h-10 bg-[var(--color-accent)] rounded-full flex items-center justify-center">
                  <div class="w-3 h-3 bg-white rounded-full"></div>
                </div>
              </div>
              <div>
                <p class="font-[var(--font-heading)] text-2xl font-extrabold text-[var(--color-text-muted)] mb-1">{m.year}</p>
                <h3 class="font-[var(--font-heading)] text-lg font-bold text-[var(--color-text)] mb-2">{m.title}</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.description}</p>
              </div>
            </div>

            <!-- Desktop layout: alternating left/right -->
            <div class={`hidden md:block w-1/2 pb-16 ${i % 2 === 0 ? 'pr-16 text-right' : 'pl-16 text-left'}`}>
              <p class="font-[var(--font-heading)] text-3xl font-extrabold text-[var(--color-text-muted)] mb-1">{m.year}</p>
              <h3 class="font-[var(--font-heading)] text-xl font-bold text-[var(--color-text)] mb-2">{m.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.description}</p>
            </div>

            <!-- Circle node (desktop) -->
            <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 z-10 mt-1">
              <div class="w-10 h-10 bg-[var(--color-accent)] rounded-full flex items-center justify-center ring-4 ring-[var(--color-surface)]">
                <div class="w-3 h-3 bg-white rounded-full"></div>
              </div>
            </div>

            <!-- Empty spacer (desktop) -->
            <div class="hidden md:block w-1/2"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
