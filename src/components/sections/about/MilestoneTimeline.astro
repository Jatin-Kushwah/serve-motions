---
const milestones = [
  {
    year: '2020',
    title: 'Founded',
    description: 'NovaMark Digital launched with three clients and a clear mission: results over reports.',
  },
  {
    year: '2021',
    title: 'First 50 Clients',
    description: 'Expanded from SEO into paid media and brand identity. Team grew to 12 specialists.',
  },
  {
    year: '2023',
    title: 'International Expansion',
    description: 'Opened new markets in the UK and Singapore. Recognised in Marketing Week\'s Top 50 Agencies.',
  },
  {
    year: '2025',
    title: '200+ Clients',
    description: 'Serving growth-stage brands across 18 industries. $120M in tracked client revenue growth.',
  },
];
---

<section class="py-28 px-6 bg-[var(--color-surface)]" data-animate>
  <div class="max-w-7xl mx-auto">
    <div class="mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent-alt)] mb-4">Our Journey</p>
      <h2 class="font-[var(--font-heading)] text-4xl md:text-5xl font-bold text-[var(--color-text)] leading-tight max-w-md">
        Five years of earned growth.
      </h2>
    </div>

    <!-- Desktop: horizontal -->
    <div class="hidden lg:grid grid-cols-4 gap-8 relative">
      <div class="absolute top-5 left-12 right-12 h-px bg-[var(--color-border)]" aria-hidden="true"></div>
      {milestones.map((m) => (
        <div>
          <div class="w-10 h-10 bg-[var(--color-accent)] rounded-full flex items-center justify-center mb-6 relative z-10">
            <div class="w-3 h-3 bg-[var(--color-text)] rounded-full"></div>
          </div>
          <p class="font-[var(--font-heading)] text-2xl font-extrabold text-[var(--color-text-muted)] mb-1">{m.year}</p>
          <h3 class="font-[var(--font-heading)] text-lg font-bold text-[var(--color-text)] mb-2">{m.title}</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.description}</p>
        </div>
      ))}
    </div>

    <!-- Mobile: vertical -->
    <div class="lg:hidden space-y-8">
      {milestones.map((m) => (
        <div class="flex gap-6">
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 bg-[var(--color-accent)] rounded-full flex items-center justify-center shrink-0">
              <div class="w-3 h-3 bg-[var(--color-text)] rounded-full"></div>
            </div>
            <div class="w-px flex-1 bg-[var(--color-border)] mt-2" aria-hidden="true"></div>
          </div>
          <div class="pb-8">
            <p class="font-[var(--font-heading)] text-xl font-extrabold text-[var(--color-text-muted)] mb-1">{m.year}</p>
            <h3 class="font-[var(--font-heading)] text-lg font-bold text-[var(--color-text)] mb-2">{m.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{m.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
