---
import Button from '@/components/ui/Button.astro';

interface Props {
  headline: string;
  cta: string;
  href: string;
}

const { headline, cta, href } = Astro.props;
---

<section class="bg-[var(--color-accent)] py-24 px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
    <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl lg:text-5xl font-extrabold text-[var(--color-text)] max-w-xl leading-tight">
      {headline}
    </h2>
    <Button href={href} variant="outline">
      {cta}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </Button>
  </div>
</section>
