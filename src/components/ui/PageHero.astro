---
interface Props {
  headline: string;
  intro: string;
  accentWord?: string;
}

const { headline, intro, accentWord } = Astro.props;

const headlineWithAccent = accentWord
  ? headline.replace(accentWord, `<span class="accent-underline">${accentWord}</span>`)
  : headline;
---

<section class="pt-40 pb-24 px-6 bg-[var(--color-bg)] relative overflow-hidden">
  <!-- Subtle orb -->
  <div class="absolute pointer-events-none" aria-hidden="true" style="top: -20%; right: -10%; width: 40vw; height: 40vw; max-width: 500px; max-height: 500px; background: radial-gradient(ellipse 70% 70% at center, rgba(79,110,247,0.07), transparent);"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="max-w-3xl">
      <h1
        class="font-[var(--font-heading)] text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.05] text-[var(--color-text)] mb-6"
        set:html={headlineWithAccent}
        data-splitting
      />
      <p class="text-lg md:text-xl text-[var(--color-text-muted)] leading-relaxed max-w-xl">
        {intro}
      </p>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  const mm = gsap.matchMedia();

  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const chars = document.querySelectorAll('.pt-40 [data-splitting] .char');
    if (chars.length === 0) return;

    gsap.fromTo(
      chars,
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7, ease: 'power3.out', stagger: 0.025, delay: 0.2 }
    );
  });
</script>
